    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "semantic-release": "25.0.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm exec eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
